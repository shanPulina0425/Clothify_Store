<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>

<StackPane fx:id="mainRoot" prefHeight="720.0" prefWidth="1080.0" styleClass="root-pane" stylesheets="@../Styles/clothify.css" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ClothifyStoreController">
    <children>
        <BorderPane>

            <top>
                <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="10.0" styleClass="nav-bar" BorderPane.alignment="CENTER">
                    <children>
                        <Label styleClass="logo-text" text="CLOTHIFY" />

                        <Region HBox.hgrow="ALWAYS" />

                        <HBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Button mnemonicParsing="false" styleClass="nav-link" text="WOMEN" />
                                <Button mnemonicParsing="false" styleClass="nav-link" text="MEN" />
                                <Button mnemonicParsing="false" styleClass="nav-link" text="UNISEX" />
                                <Button mnemonicParsing="false" styleClass="nav-link" text="COSMETICS" />
                                <Button mnemonicParsing="false" styleClass="nav-link" text="JEWELLERY" />
                            </children>
                        </HBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <HBox alignment="CENTER_RIGHT" spacing="15.0">
                            <children>
                                <HBox alignment="CENTER" style="-fx-border-color: #DDDDDD; -fx-border-radius: 20; -fx-padding: 0 10 0 10; -fx-background-color: #F9F9F9; -fx-background-radius: 20;">
                                    <TextField fx:id="txtSearch" promptText="Search items..." style="-fx-background-color: transparent; -fx-border-width: 0;" />
                                    <Button mnemonicParsing="false" onAction="#handleSearch" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-weight: bold;" text="Go" />
                                </HBox>

                                <Button fx:id="btnCart" mnemonicParsing="false" onAction="#handleShowCart" styleClass="icon-button" text="Cart (0)" />
                                <Button mnemonicParsing="false" onAction="#handleShowLogin" styleClass="icon-button" text="Login / Admin" />
                            </children>
                        </HBox>
                    </children>
                </HBox>
            </top>

            <center>
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" BorderPane.alignment="CENTER">
                    <content>
                        <VBox alignment="TOP_CENTER" spacing="30.0">
                            <padding>
                                <Insets bottom="40.0" left="40.0" right="40.0" top="30.0" />
                            </padding>
                            <children>

                                <StackPane prefHeight="300.0" styleClass="hero-banner">
                                    <children>
                                        <VBox alignment="CENTER" spacing="10.0">
                                            <children>
                                                <Label styleClass="hero-text" text="STANDOUT COLLECTION" />
                                                <Label styleClass="hero-subtext" text="Looks like you change the vibe—without changing outfits." />
                                            </children>
                                        </VBox>
                                    </children>
                                </StackPane>

                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label styleClass="section-title" text="LATEST IN STORE THIS WEEK" />
                                    </children>
                                </HBox>

                                <FlowPane fx:id="itemGrid" hgap="25.0" vgap="30.0" alignment="CENTER_LEFT" />

                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </center>

        </BorderPane>

        <StackPane fx:id="popupOverlay" style="-fx-background-color: rgba(0,0,0,0.6);" visible="false">

            <children>
                <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="350.0" prefWidth="400.0" spacing="20.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 15, 0, 0, 5);">
                    <children>
                        <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #111;" text="Admin Login" />

                        <Label fx:id="lblLoginError" style="-fx-text-fill: #E53935; -fx-font-weight: bold;" text="" />

                        <VBox spacing="8.0" style="-fx-padding: 0 40 0 40;">
                            <children>
                                <Label style="-fx-text-fill: #555; -fx-font-weight: bold;" text="Username" />
                                <TextField fx:id="txtUsername" promptText="Enter admin username" style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #DDD; -fx-border-radius: 5;" />
                            </children>
                        </VBox>

                        <VBox spacing="8.0" style="-fx-padding: 0 40 0 40;">
                            <children>
                                <Label style="-fx-text-fill: #555; -fx-font-weight: bold;" text="Password" />
                                <PasswordField fx:id="txtPassword" promptText="Enter password" style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #DDD; -fx-border-radius: 5;" />
                            </children>
                        </VBox>

                        <HBox alignment="CENTER" spacing="15.0" style="-fx-padding: 10 0 0 0;">
                            <children>
                                <Button mnemonicParsing="false" onAction="#handleLoginSubmit" style="-fx-background-color: #111; -fx-text-fill: white; -fx-padding: 10 30; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Login" />
                                <Button mnemonicParsing="false" onAction="#handleClosePopup" style="-fx-background-color: transparent; -fx-border-color: #CCC; -fx-border-radius: 5; -fx-padding: 10 25; -fx-cursor: hand;" text="Cancel" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </StackPane>

        <StackPane fx:id="cartOverlay" alignment="CENTER_RIGHT" style="-fx-background-color: rgba(0,0,0,0.4);" visible="false">
            <children>
                <VBox prefWidth="350.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 20, 0, 0, 0);">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Your Cart" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#handleCloseCart" style="-fx-background-color: transparent; -fx-font-weight: bold; -fx-cursor: hand;" text="X" />
                            </children>
                        </HBox>

                        <VBox fx:id="cartItemsContainer" spacing="10.0" VBox.vgrow="ALWAYS" />

                        <HBox>
                            <children>
                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Total:" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="lblCartTotal" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #E53935;" text="Rs. 0.0" />
                            </children>
                        </HBox>

                        <TextField fx:id="txtCustomerName" promptText="Enter your name to checkout" style="-fx-padding: 10;" />
                        <Label fx:id="lblCheckoutStatus" textFill="#2e7d32" wrapText="true" />

                        <Button mnemonicParsing="false" onAction="#handleCheckout" prefWidth="350.0" style="-fx-background-color: #111; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 15; -fx-cursor: hand;" text="Checkout securely" />
                    </children>
                </VBox>
            </children>
        </StackPane>

    </children>
</StackPane>