<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="1080.0" style="-fx-background-color: #F8F9FA;" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AdminController">

    <top>
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #111111; -fx-padding: 15 30;">
            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" text="Clothify Admin Dashboard" />
                <javafx.scene.layout.Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 5; -fx-cursor: hand;" text="Logout" />
            </children>
        </HBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
            <tabs>

                <Tab text="Manage Inventory">
                    <content>
                        <BorderPane>
                            <left>
                                <VBox prefWidth="320.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 30; -fx-border-color: #DDDDDD; -fx-border-width: 0 1 0 0;">
                                    <children>
                                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Add New Item" />
                                        <VBox spacing="5.0">
                                            <Label text="Product Name" textFill="#555555" />
                                            <TextField fx:id="txtName" promptText="e.g. Graphic T-Shirt" style="-fx-padding: 8;" />
                                        </VBox>
                                        <VBox spacing="5.0">
                                            <Label text="Category" textFill="#555555" />
                                            <ComboBox fx:id="cmbCategory" prefWidth="300.0" promptText="Select Category" style="-fx-padding: 3;" />
                                        </VBox>
                                        <VBox spacing="5.0">
                                            <Label text="Price (Rs.)" textFill="#555555" />
                                            <TextField fx:id="txtPrice" promptText="e.g. 2500" style="-fx-padding: 8;" />
                                        </VBox>
                                        <VBox spacing="5.0">
                                            <Label text="Stock Quantity" textFill="#555555" />
                                            <TextField fx:id="txtQty" promptText="e.g. 50" style="-fx-padding: 8;" />
                                        </VBox>
                                        <Label fx:id="lblStatus" textFill="#e53935" wrapText="true" />
                                        <Button mnemonicParsing="false" onAction="#handleAddItem" prefWidth="300.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-cursor: hand; -fx-background-radius: 5;" text="Add to Inventory" />
                                    </children>
                                </VBox>
                            </left>
                            <center>
                                <VBox spacing="15.0" style="-fx-padding: 30;">
                                    <children>
                                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Inventory List" />
                                        <TableView fx:id="itemTable" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                                                <TableColumn fx:id="colName" prefWidth="250.0" text="Product Name" />
                                                <TableColumn fx:id="colCategory" prefWidth="150.0" text="Category" />
                                                <TableColumn fx:id="colPrice" prefWidth="120.0" text="Price (Rs.)" />
                                                <TableColumn fx:id="colQty" prefWidth="100.0" text="In Stock" />
                                            </columns>
                                        </TableView>
                                        <HBox alignment="CENTER_RIGHT">
                                            <children>
                                                <Button mnemonicParsing="false" onAction="#handleDeleteItem" style="-fx-background-color: #E53935; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-cursor: hand; -fx-background-radius: 5;" text="Delete Selected Item" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </center>
                        </BorderPane>
                    </content>
                </Tab>

                <Tab text="Manage Users">
                    <content>
                        <BorderPane>
                            <left>
                                <VBox prefWidth="320.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 30; -fx-border-color: #DDDDDD; -fx-border-width: 0 1 0 0;">
                                    <children>
                                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Register New Admin" />
                                        <VBox spacing="5.0">
                                            <Label text="Admin Username" textFill="#555555" />
                                            <TextField fx:id="txtAdminUser" promptText="Enter username" style="-fx-padding: 8;" />
                                        </VBox>
                                        <VBox spacing="5.0">
                                            <Label text="Admin Password" textFill="#555555" />
                                            <PasswordField fx:id="txtAdminPass" promptText="Enter password" style="-fx-padding: 8;" />
                                        </VBox>
                                        <Label fx:id="lblUserStatus" textFill="#e53935" wrapText="true" />
                                        <Button mnemonicParsing="false" onAction="#handleAddAdmin" prefWidth="300.0" style="-fx-background-color: #111; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-cursor: hand; -fx-background-radius: 5;" text="Create Admin Account" />
                                    </children>
                                </VBox>
                            </left>
                            <center>
                                <VBox spacing="15.0" style="-fx-padding: 30;">
                                    <children>
                                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="System Users" />
                                        <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colUserId" prefWidth="80.0" text="User ID" />
                                                <TableColumn fx:id="colUsername" prefWidth="250.0" text="Username" />
                                                <TableColumn fx:id="colRole" prefWidth="150.0" text="Role" />
                                            </columns>
                                        </TableView>
                                        <HBox alignment="CENTER_RIGHT">
                                            <children>
                                                <Button mnemonicParsing="false" onAction="#handleDeleteUser" style="-fx-background-color: #E53935; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-cursor: hand; -fx-background-radius: 5;" text="Delete Selected User" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </center>
                        </BorderPane>
                    </content>
                </Tab>

            </tabs>
        </TabPane>
    </center>
</BorderPane>